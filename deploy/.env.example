# Copy to .env on the server — never commit this file

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DB=musings
POSTGRES_USER=musings
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Flask app ──────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_run_python3_-c_"import_secrets;print(secrets.token_hex(32))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ── Watchtower Slack notifications ─────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
